{
  "name": "empty-nyc-carriage",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.8.0 <25",
    "npm": ">=11.6.0 <12"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "setup:local": "tsx scripts/setup_local.ts",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts",
    "bootstrap": "npm run setup:local && npm run db:up && npm run db:migrate && npm run db:seed",
    "data:download": "tsx scripts/import_all.ts",
    "data:download:gtfs": "tsx scripts/download_static_gtfs.ts",
    "data:download:socrata": "tsx scripts/download_socrata_dataset.ts",
    "data:bootstrap": "npm run data:download && npm run data:import && npm run data:build-zone-profiles && npm run data:validate-zone-profiles",
    "data:import": "npm run data:import:gtfs && npm run data:import:entrances",
    "data:import:gtfs": "tsx scripts/import_static_gtfs.ts",
    "data:import:entrances": "tsx scripts/import_socrata_entrances.ts",
    "data:build-zone-profiles": "tsx scripts/build_zone_profiles.ts",
    "data:validate-zone-profiles": "tsx scripts/validate_zone_profiles.ts",
    "start": "next start",
    "test": "vitest run",
    "typecheck": "next typegen && tsc --noEmit",
    "verify": "npm test && npm run typecheck && npm run build"
  },
  "dependencies": {
    "@tailwindcss/postcss": "4.2.4",
    "adm-zip": "0.5.17",
    "csv-parse": "6.2.1",
    "drizzle-orm": "0.45.2",
    "next": "16.2.4",
    "pg": "8.20.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tailwindcss": "4.2.4"
  },
  "overrides": {
    "postcss": "8.5.13"
  },
  "devDependencies": {
    "@types/adm-zip": "0.5.8",
    "@types/node": "24.10.1",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "dotenv": "17.4.2",
    "drizzle-kit": "0.31.10",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
